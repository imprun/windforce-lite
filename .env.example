# Local windforce-lite development against the shared dhworker/devstack PostgreSQL.
#
# Copy this file to .env when running windforce-lite from this repo.
# Docker Compose services reach the host-published devstack port through
# host.docker.internal and share the devstack catalog/data volume. Host-run
# Makefile targets use POSTGRES_DSN.
WINDFORCE_LITE_DATABASE_URL=postgres://postgres@host.docker.internal:15432/windforce_lite?sslmode=disable
POSTGRES_DSN=postgres://postgres@127.0.0.1:15432/windforce_lite?sslmode=disable
WINDFORCE_LITE_DATA_VOLUME=dhworker-dev_windforce-lite-data
WINDFORCE_LITE_DATA_VOLUME_EXTERNAL=true
WINDFORCE_LITE_API_PORT=18091
WINDFORCE_LITE_WEB_PORT=18090

# Optional: Python package indexes used only during worker source prepare.
# Do not commit credentials in this file; put personal token-bearing URLs only in local .env.
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=
PIP_FIND_LINKS=
PIP_NO_INDEX=
PIP_CERT=
PIP_CLIENT_CERT=
