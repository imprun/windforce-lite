# Local windforce-core development with the repository-owned PostgreSQL.
#
# Copy this file to .env when running windforce-core from this repo.
# Docker Compose services use the postgres service name. Host-run Makefile
# targets use POSTGRES_DSN through the published port.
WINDFORCE_LITE_DATABASE_URL=postgres://postgres@postgres:5432/windforce_core?sslmode=disable
POSTGRES_DSN=postgres://postgres@127.0.0.1:15432/windforce_core?sslmode=disable
WINDFORCE_POSTGRES_PORT=15432
WINDFORCE_LITE_POSTGRES_VOLUME=windforce-core_postgres-data
WINDFORCE_LITE_POSTGRES_VOLUME_EXTERNAL=false
WINDFORCE_LITE_DATA_VOLUME=windforce-core_windforce-data
WINDFORCE_LITE_DATA_VOLUME_EXTERNAL=false
WINDFORCE_LITE_NETWORK=windforce-core
WINDFORCE_LITE_API_PORT=18091
WINDFORCE_LITE_EXECUTION_API_PORT=18092
WINDFORCE_LITE_WEB_PORT=18090
WINDFORCE_LITE_WEBHOOK_METRICS_PORT=18093

# Release webhook dispatcher. Private endpoints require an explicit host or CIDR allowlist.
# HTTP loopback is only for a host-run local receiver.
SECRET_KEY=
SECRET_KEY_PREVIOUS=
WINDFORCE_LITE_WEBHOOK_DISPATCH_INTERVAL=500ms
WINDFORCE_LITE_WEBHOOK_REQUEST_TIMEOUT=10s
WINDFORCE_LITE_WEBHOOK_MAX_ATTEMPTS=8
WINDFORCE_LITE_WEBHOOK_LEASE_TTL=30s
WINDFORCE_LITE_WEBHOOK_ALLOWED_HOSTS=
WINDFORCE_LITE_WEBHOOK_ALLOWED_CIDRS=
WINDFORCE_LITE_WEBHOOK_ALLOW_INSECURE_LOOPBACK=false
WINDFORCE_LITE_WEBHOOK_METRICS_ADDR=:9090
WINDFORCE_LITE_WEBHOOK_SUCCESS_RETENTION_DAYS=30
WINDFORCE_LITE_WEBHOOK_FAILURE_RETENTION_DAYS=90
WINDFORCE_LITE_WEBHOOK_RETENTION_INTERVAL=10m
WINDFORCE_LITE_WEBHOOK_RETENTION_BATCH_SIZE=1000
WINDFORCE_LITE_WEBHOOK_RETENTION_TIME_BUDGET=5s

# Optional: Python package indexes used only during worker source prepare.
# Do not commit credentials in this file; put personal token-bearing URLs only in local .env.
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=
PIP_FIND_LINKS=
PIP_NO_INDEX=
PIP_CERT=
PIP_CLIENT_CERT=

# Optional worker-owned runtime service binding.
# Apps declare what they need; workers inject runtime metadata immediately
# before action execution. Prefer TOKEN_FILE for shared environments.
WINDFORCE_AUTH_SESSION_URL=
WINDFORCE_AUTH_SESSION_TOKEN=
WINDFORCE_AUTH_SESSION_TOKEN_FILE=
WINDFORCE_AUTH_SESSION_TIMEOUT_MS=15000

# Local development worker script logging. docker-compose.dev.yml maps this to
# LOG_LEVEL and PYTHON_LOG_LEVEL for FCODE/SDK stdout/stderr capture.
WINDFORCE_LITE_DEV_SCRIPT_LOG_LEVEL=DEBUG
