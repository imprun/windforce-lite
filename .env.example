# Local windforce-lite development against the shared dhworker/devstack PostgreSQL.
#
# Copy this file to .env when running windforce-lite from this repo.
# dhworker/devstack publishes PostgreSQL on 127.0.0.1:15432.
WINDFORCE_LITE_DATABASE_URL=postgres://postgres@127.0.0.1:15432/windforce_lite?sslmode=disable
